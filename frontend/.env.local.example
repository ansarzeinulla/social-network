NEXT_PUBLIC_API_URL=http://localhost:8080

# Mock toggles. Flip to "true" while a backend module is being built; the UI
# falls back to local mocks so frontend devs aren't blocked.
# When the backend module is ready and tested, flip back to "false".
NEXT_PUBLIC_USE_MOCK_FOLLOWERS=false
NEXT_PUBLIC_USE_MOCK_PROFILE=false
NEXT_PUBLIC_USE_MOCK_NOTIFICATIONS=false
NEXT_PUBLIC_USE_MOCK_COMMENTS=false
NEXT_PUBLIC_USE_MOCK_CHAT=false
NEXT_PUBLIC_USE_MOCK_GROUPS=false
